# Local server env template (copy to apps/server/.env)

# Allowed web origins for local/dev usage
CORS_ORIGIN=https://fightclaw.com,https://fightclaw.pages.dev,http://localhost:3001

# Local/dev runner and auth keys
DEV_AGENT_KEY=replace_with_local_dev_agent_key
API_KEY_PEPPER=replace_with_random_hex_secret
ADMIN_KEY=replace_with_random_hex_secret
INTERNAL_RUNNER_KEY=replace_with_random_secret
PROMPT_ENCRYPTION_KEY=replace_with_base64_32_bytes

# Optional build-time Sentry upload token
SENTRY_AUTH_TOKEN=
