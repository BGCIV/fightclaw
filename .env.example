# Shared deploy/runtime env template (copy to .env and fill values)
# Used by packages/infra/alchemy.run.ts and local utility scripts.

# Required secrets
API_KEY_PEPPER=replace_with_random_hex_secret
ADMIN_KEY=replace_with_random_hex_secret
INTERNAL_RUNNER_KEY=replace_with_random_secret
PROMPT_ENCRYPTION_KEY=replace_with_base64_32_bytes

# Runtime config
CORS_ORIGIN=http://localhost:5173
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

# Optional Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Optional SIM/LLM helpers
LLM_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_REFERRER=http://localhost:5173
OPENROUTER_TITLE=Fightclaw Sim
